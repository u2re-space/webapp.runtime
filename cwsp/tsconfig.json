{
    "include": [
        "**/*.ts",
        "**/*.js"
    ],
    "exclude": [
        "./node_modules/**/*",
        "./dist/**/*",
        "./portable/**/*"
    ],
    "compilerOptions": {
        "baseUrl": "./",
        "ignoreDeprecations": "6.0",
        "paths": {
            "@protocol/*": [
                "./endpoint/sserver/protocol/*"
            ],
            "@admin/*": [
                "./endpoint/sserver/admin/*"
            ],
            "@config/*": [
                "./endpoint/sserver/config/*"
            ],
            "@server-v2/*": [
                "./endpoint/sserver/"
            ],
            "@server/*": [
                "./endpoint/sserver/"
            ],
            "@inputs/*": [
                "./endpoint/sserver/inputs/*"
            ],
            "@utils/*": [
                "./endpoint/server/utils/*"
            ]
        },
        "outDir": "./dist/",
        "target": "ES2025",
        "module": "NodeNext",
        "moduleResolution": "NodeNext",
        "lib": [
            "ES2025",
            "DOM"
        ],
        "esModuleInterop": true,
        "allowImportingTsExtensions": true,
        "allowArbitraryExtensions": true,
        "allowSyntheticDefaultImports": true,
        "allowUmdGlobalAccess": true,
        "allowUnreachableCode": true,
        "allowUnusedLabels": true,
        "skipLibCheck": true,
        "strict": false,
        "noImplicitAny": false,
        "noImplicitThis": false,
        "forceConsistentCasingInFileNames": true,
        "allowJs": true,
        "declaration": false,
        "inlineSources": true,
        "inlineSourceMap": true,
        "sourceMap": false,
        "experimentalDecorators": true,
        "types": [
            "node"
        ],
        "noEmit": true,
        "noEmitOnError": true,
        "noEmitHelpers": true
    },
    "compileOnSave": false
}
