{
  "name": "cwsp-runtime",
  "version": "1.0.0",
  "description": "CWSP Unified Runtime",
  "type": "module",
  "scripts": {
    "build:js": "npm install --include=dev",
    "start:js": "node ./fastify-js/index.mjs --port 443 --address 0.0.0.0 --debug --options --esm",
    "dev:js": "npm run start:js",
    "test:js": "npm run test:dev:js",
    "test:dev:js": "vite dev --config vite.config.ts",
    "test:test:js": "echo 'No tests configured for fastify-server' && exit 0",
    "dev": "node ../scripts/dev.mjs",
    "build": "node ../scripts/build-cws-android.mjs",
    "build:portable": "node ../scripts/build-portable.mjs",
    "build:portable:readable": "node ../scripts/build-portable.mjs --readable",
    "portable:generate": "node ../scripts/generate-portable-configs.mjs",
    "config:sync": "node ../scripts/sync-endpoint-config-layout.mjs",
    "config:prepare": "npm run portable:generate && npm run config:sync",
    "config:https:local": "CWS_HTTPS_KEY=fs:../https/local/multi.key CWS_HTTPS_CERT=fs:../https/local/multi.crt CWS_HTTPS_CA=fs:../https/local/rootCA.crt CWS_HTTPS_CERT_MODULE=fs:./certificate.mjs npm run config:prepare",
    "config:https:private": "CWS_HTTPS_KEY=fs:../https/private/multi.key CWS_HTTPS_CERT=fs:../https/private/multi.crt CWS_HTTPS_CA=fs:../https/private/rootCA.crt CWS_HTTPS_CERT_MODULE=fs:./certificate.mjs npm run config:prepare",
    "deploy:server:ssh": "node ../scripts/deploy-cwsp-server.mjs",
    "deploy:server:ssh:hosts": "npm run config:prepare && node ../scripts/deploy-cwsp-hosts.mjs",
    "distribute": "npm run deploy:server:ssh",
    "build:distribute": "npm run deploy:server:ssh",
    "build:portable:distribute": "npm run build:portable:readable && npm run deploy:portable:ssh",
    "build:electron": "node ../scripts/build-electron.mjs",
    "build:electron:native": "node ../scripts/build-electron-native.mjs",
    "build:electron:native:dir": "node ../scripts/build-electron-native.mjs --dir",
    "build:electron:windows": "node ../scripts/build-electron.mjs && node ../scripts/build-electron-native.mjs --win",
    "build:electron:linux": "node ../scripts/build-electron.mjs && node ../scripts/build-electron-native.mjs --linux",
    "build:electron:mac": "node ../scripts/build-electron.mjs && node ../scripts/build-electron-native.mjs --mac",
    "build:electron:darwin": "node ../scripts/build-electron.mjs && node ../scripts/build-electron-native.mjs --mac",
    "build:electron:mwl": "node ../scripts/build-electron.mjs && node ../scripts/build-electron-native.mjs -mwl",
    "build:electron:android": "node ../scripts/build-cws-android.mjs",
    "build:android": "node ../scripts/build-cws-android.mjs",
    "build:cws-android": "node ../scripts/build-cws-android.mjs",
    "build:android:unified": "node ../scripts/build-cws-android.mjs",
    "build:android:standalone": "node ../scripts/build-cws-android.mjs --standalone-cws",
    "build:electron:all": "npm run build:electron && npm run build:electron:native",
    "build:capacitor:web": "node ../scripts/build-capacitor-web.mjs",
    "build:capacitor": "node ../scripts/build-capacitor.mjs",
    "build:capacitor:android": "node ../scripts/build-capacitor-android.mjs",
    "cap:add:android": "node ../scripts/ensure-capacitor-android.mjs",
    "cap:open:android": "npx cap open android",
    "cap:sync": "node ../scripts/build-capacitor-web.mjs --skip-portable && npx cap sync android && node ../scripts/patch-capacitor-android-network.mjs",
    "cap:sync:lan": "CWS_CAP_CLEAR_DOMAINS=${CWS_CAP_CLEAR_DOMAINS:-localhost,127.0.0.1,10.0.2.2,192.168.0.200,192.168.0.201,192.168.0.110,192.168.0.111,192.168.0.196,192.168.0.208,100.110.152.73,100.99.178.6,100.90.155.65} CWS_CAP_ALLOW_NAVIGATION=${CWS_CAP_ALLOW_NAVIGATION:-https://localhost,http://localhost,https://192.168.0.200,http://192.168.0.200,https://192.168.0.201,http://192.168.0.201,https://192.168.0.110,http://192.168.0.110,https://192.168.0.111,http://192.168.0.111,https://192.168.0.196,http://192.168.0.196,https://192.168.0.208,http://192.168.0.208,https://100.110.152.73,https://100.99.178.6,https://100.90.155.65} npm run cap:sync",
    "cap:patch:android-net": "node ../scripts/patch-capacitor-android-network.mjs",
    "hint:capacitor-apk": "node ../scripts/hint-capacitor-apk.mjs",
    "start": "node dist/portable/cwsp.mjs",
    "start:pm2": "pm2 start config/ecosystem.portable.config.cjs --only cwsp --update-env -- --config ./config/portable.config.json",
    "start:pm2:server": "pm2 start config/ecosystem.server.config.cjs --only cwsp --update-env",
    "deploy:portable:ssh": "node ../scripts/deploy-cwsp-portable.mjs",
    "pack:portable": "node ../pack-portable.mjs",
    "pack:extension": "node ../pack-extension.mjs",
    "debug": "node --inspect-brk -r tsx server/index.ts",
    "check:types": "npx tsc --ignoreConfig --noEmit --pretty false --module nodenext --moduleResolution nodenext --target es2022 --lib es2022,dom --types node --allowImportingTsExtensions true server/client/vds-fake-client.ts server/client/vds-fake-client-ws.ts server/client/route-compat-iterator.ts server/client/protocol-compat-matrix.ts server/client/client-contract.ts server/socket/client-contract.ts server/inputs/drivers/clipboardy.ts",
    "test:protocol-matrix": "tsx server/client/protocol-compat-matrix.ts",
    "test:compat": "npm run check:types && npm run test:protocol-matrix",
    "test:vds-client": "tsx server/client/vds-fake-client.ts",
    "test:vds-client:ws": "tsx server/client/vds-fake-client-ws.ts",
    "test:auto-iterator": "tsx server/client/route-compat-iterator.ts",
    "test:auto-iterator:quick": "CWS_ITER_RETRIES=1 CWS_ITER_TIMEOUT_MS=3500 CWS_ITER_ENDPOINTS=https://192.168.0.200:8443/,https://192.168.0.110:8443/,https://45.147.121.152:8443/ tsx server/client/route-compat-iterator.ts",
    "diag:auto": "node ../scripts/auto-diagnose-links.mjs",
    "diag:auto:restart": "node ../scripts/auto-diagnose-links.mjs --restart",
    "diag:auto:contour": "CWS_AUTOMATION_ACTIVE_PEERS=L-192.168.0.110,L-192.168.0.196,L-192.168.0.200 node ../scripts/auto-diagnose-links.mjs --restart",
    "diag:adb": "node ../scripts/auto-diagnose-links.mjs --adb-only",
    "diag:pm2": "node ../scripts/auto-diagnose-links.mjs --pm2-only"
  },
  "devDependencies": {
    "@cap-js-community/websocket": ">=1.10.0",
    "@capacitor/android": ">=8.3.0",
    "@capacitor/cli": ">=8.3.0",
    "@capacitor/clipboard": "^8.0.1",
    "@capacitor/core": ">=8.3.0",
    "@electron/rebuild": ">=4.0.3",
    "@fastify/caching": ">=9.0.3",
    "@fastify/compress": ">=8.3.1",
    "@fastify/cors": ">=11.2.0",
    "@fastify/etag": ">=6.1.0",
    "@fastify/formbody": ">=8.0.2",
    "@fastify/multipart": "^10.0.0",
    "@fastify/static": ">=9.1.0",
    "@gachlab/capacitor-permissions": "^2.1.0",
    "@phosphor-icons/core": "^2.1.1",
    "@webviewjs/webview": ">=0.1.4",
    "capacitor-native-settings": "^8.1.0",
    "clipboardy": ">=5.3.1",
    "close-with-grace": ">=2.1.0",
    "dotenv": ">=16.4.7",
    "electron": ">=42.0.0-beta.1",
    "electron-builder": "^26.8.1",
    "esbuild": ">=0.24.0",
    "fastify": "^5.8.4",
    "socket.io": ">=4.8.3",
    "socket.io-client": ">=4.8.3",
    "tsx": ">=4.7.1",
    "typescript": ">=6.0.0-beta",
    "vite": "^8.0.7"
  },
  "dependencies": {
    "ws": "^8.20.0"
  }
}
