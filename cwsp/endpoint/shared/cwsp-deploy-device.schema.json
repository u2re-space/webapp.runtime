{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cwsp.local/schemas/deploy-device-manifest.json",
  "title": "CWSP SSH deploy manifest",
  "type": "object",
  "required": ["devices"],
  "properties": {
    "schemaVersion": { "type": "integer" },
    "devices": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "os", "ssh"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "nodeId": { "type": "string" },
          "os": { "enum": ["windows", "linux", "win32"] },
          "ssh": { "type": "string", "pattern": "^[^@]+@[^@]+$" },
          "sshPort": { "type": "string" },
          "portableConfig": { "type": "string", "description": "Relative to cwsp endpoint root (e.g. config/portable.config.110.json)" },
          "pathCandidates": { "type": "array", "items": { "type": "string" } },
          "profiles": { "type": "array", "items": { "type": "string" } },
          "legacyProfile": { "type": "string", "description": "Maps to CWSP_DEPLOY_HOSTS=named profile (windows110, linux200)" }
        }
      }
    }
  }
}
