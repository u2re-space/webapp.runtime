{
    "name": "fastify-server",
    "version": "0.0.1",
    "description": "",
    "type": "module",
    "engines": {
        "node": ">=24"
    },
    "keywords": [
        "fastify",
        "server"
    ],
    "license": "MIT",
    "private": false,
    "scripts": {
