<?xml version="1.0" encoding="utf-8"?>
<!--
  CWSP Capacitor WebView: aligns with CrossWord Settings → Server (admin HTTP :8080, endpoint on LAN).
  - Cleartext HTTP only for listed hosts (localhost / emulator loopback). Add <domain> rows for
    fixed LAN IPs (e.g. 192.168.1.10) if you open http://… admin or API from the device.
  - Self-signed HTTPS (:8443): install the server CA as a user certificate on the device, or use
    a publicly trusted cert. User trust anchors are honored below (matches app allowInsecureTls intent
    only when the CA is installed — WebView does not bypass TLS from JS alone).
  Applied after every `cap sync` by scripts/patch-capacitor-android-network.mjs (android/ is gitignored).
-->
<network-security-config>
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
            <certificates src="user" />
        </trust-anchors>
    </base-config>
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="true">localhost</domain>
        <domain includeSubdomains="true">127.0.0.1</domain>
        <domain includeSubdomains="true">10.0.2.2</domain>
        <!-- Typical wireless-ADB / LAN test device (override in fork if needed) -->
        <domain includeSubdomains="false">192.168.0.196</domain>
        <domain includeSubdomains="false">192.168.0.200</domain>
        <domain includeSubdomains="false">192.168.0.110</domain>
    </domain-config>
</network-security-config>
