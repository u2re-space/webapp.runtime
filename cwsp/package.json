{
  "name": "cwsp-runtime",
  "version": "1.0.0",
  "description": "CWSP Unified Runtime",
  "type": "module",
  "scripts": {
    "dev": "tsx watch --clear-screen=false runtime/cwsp/server/index.ts",
    "build": "node runtime/scripts/build.mjs",
    "start": "node dist/server/index.js",
    "debug": "node --inspect-brk -r tsx runtime/cwsp/server/index.ts"
  },
  "devDependencies": {
    "@fastify/caching": ">=9.0.3",
    "@fastify/compress": ">=8.0.1",
    "@fastify/cors": ">=10.0.1",
    "@fastify/etag": ">=6.0.2",
    "@fastify/formbody": ">=8.0.1",
    "@fastify/multipart": ">=9.0.2",
    "@fastify/static": ">=8.0.3",
    "@phosphor-icons/core": "^2.1.1",
    "clipboardy": ">=4.0.0",
    "close-with-grace": ">=2.1.0",
    "dotenv": ">=16.4.7",
    "electron": ">=42.0.0-beta.1",
    "fastify": ">=5.8.4",
    "socket.io": ">=4.7.5",
    "tsx": ">=4.7.1",
    "typescript": ">=5.4.3"
  }
}
