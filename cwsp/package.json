{
  "name": "cwsp-runtime",
  "version": "1.0.0",
  "description": "CWSP Unified Runtime",
  "type": "module",
  "scripts": {
    "build:frontend:crossword": "npm --prefix ../../apps/CrossWord run build:pwa",
    "build:frontend:all": "npm --prefix ../../apps/CrossWord run build:all",
    "build:electron": "npm run build:frontend:crossword && node scripts/build-electron.mjs",
    "build:electron:native": "npm run build:frontend:crossword && node scripts/build-electron-native.mjs",
    "build:electron:native:dir": "node scripts/build-electron-native.mjs --dir",
    "build:electron:windows": "node scripts/build-electron.mjs && node scripts/build-electron-native.mjs --win",
    "build:electron:linux": "node scripts/build-electron.mjs && node scripts/build-electron-native.mjs --linux",
    "build:electron:mac": "node scripts/build-electron.mjs && node scripts/build-electron-native.mjs --mac",
    "build:electron:darwin": "node scripts/build-electron.mjs && node scripts/build-electron-native.mjs --mac",
    "build:electron:mwl": "node scripts/build-electron.mjs && node scripts/build-electron-native.mjs -mwl",
    "build:electron:android": "npm run build:frontend:crossword && node scripts/build-cws-android.mjs",
    "build:android": "npm run build:frontend:crossword && node scripts/build-cws-android.mjs",
    "build:cws-android": "npm run build:frontend:crossword && node scripts/build-cws-android.mjs",
    "build:android:unified": "npm run build:frontend:crossword && node scripts/build-cws-android.mjs",
    "build:android:standalone": "npm run build:frontend:crossword && node scripts/build-cws-android.mjs --standalone-cws",
    "build:electron:all": "npm run build:electron && npm run build:electron:native",
    "build:capacitor:web": "npm run build:frontend:crossword && node scripts/build-capacitor-web.mjs",
    "build:capacitor": "npm run build:frontend:crossword && node scripts/build-capacitor.mjs",
    "build:capacitor:android": "npm run build:frontend:crossword && node scripts/build-capacitor-android.mjs",
    "build:all": "npm run build:frontend:all && npm run build:electron:all && npm run build:capacitor:android && npm run build:android:unified",
    "assemble": "npm run build:android:unified",
    "assemble:capacitor": "npm run build:capacitor:android",
    "assembly": "npm run assemble",
    "assmble": "npm run assemble",
    "cap:add:android": "node scripts/ensure-capacitor-android.mjs",
    "cap:open:android": "npx cap open android",
    "cap:sync": "node scripts/build-capacitor-web.mjs --skip-portable && npx cap sync android && node scripts/patch-capacitor-android-network.mjs",
    "cap:patch:android-net": "node scripts/patch-capacitor-android-network.mjs"
  },
  "devDependencies": {
    "@cap-js-community/websocket": "^1.10.0",
    "@capacitor/android": ">=8.3.0",
    "@capacitor/cli": ">=8.3.0",
    "@capacitor/clipboard": "^8.0.1",
    "@capacitor/core": ">=8.3.0",
    "@capacitor/http": "^0.0.2",
    "@electron/rebuild": ">=4.0.3",
    "@fastify/caching": ">=9.0.3",
    "@fastify/compress": ">=8.3.1",
    "@fastify/cors": ">=11.2.0",
    "@fastify/etag": ">=6.1.0",
    "@fastify/formbody": ">=8.0.2",
    "@fastify/multipart": "^10.0.0",
    "@fastify/static": ">=9.1.0",
    "@gachlab/capacitor-permissions": "^2.1.0",
    "@phosphor-icons/core": "^2.1.1",
    "@webviewjs/webview": ">=0.1.4",
    "capacitor-cws-bridge": "file:plugins/capacitor-cws-bridge",
    "capacitor-native-settings": "^8.1.0",
    "clipboardy": ">=5.3.1",
    "close-with-grace": ">=2.1.0",
    "dotenv": ">=16.4.7",
    "electron": ">=42.0.0-beta.1",
    "electron-builder": "^26.8.1",
    "esbuild": ">=0.24.0",
    "fastify": "^5.8.4",
    "socket.io": ">=4.8.3",
    "socket.io-client": ">=4.8.3",
    "typescript": ">=6.0.0-beta",
    "vite": "^8.0.7",
    "tsx": ">=4.7.1"
  }
}
