# Loaded by `npm run dev` (via scripts/dev.mjs). Override locally; do not commit secrets.
#
# NODE_ENV=development
# CWS_BRIDGE_MODE=active
# CWS_AI_API_KEY=
# CWS_AI_BASE_URL=
#
# Optional: force static root (absolute path to folder that contains index.html). Overrides probe order.
# CWS_FRONTEND_DIR=/absolute/path/to/built/pwa
#
# Optional: extra frontend layers (merged in order after runtime/frontend and cwsp/frontend).
# Use **built** PWA output, not the CrossWord source tree — Vite dev index.html breaks on CWSP (no /src/).
# Example after: (cd apps/CrossWord && npm run build:pwa)
# CWS_FRONTEND_SRC=/absolute/path/to/U2RE.space/apps/CrossWord/dist
#
# Bind address for Admin + Public Fastify (default 0.0.0.0 = all interfaces). Browsers still need a real IP/hostname in the URL.
# CWS_LISTEN_HOST=0.0.0.0
# Optional: print exact public URL in logs (e.g. LAN IP for phones).
# CWS_ADVERTISE_HOST=192.168.0.200
#
# If browsers show ERR_CONNECTION_REFUSED on :443, the public server did not bind (permission, port in use).
# Use an unprivileged port and open https://LAN:8443/ instead:
# CWS_PUBLIC_HTTPS_PORT=8443
#
# Legacy HTTP→HTTPS worker on port 80 (only when running web/fastify/index.ts as entry). Disable if port 80 is busy:
# CWS_SKIP_REDIRECT_WORKER=1
#
# Skip merged .dev-frontend sync (not recommended):
# CWS_SKIP_DEV_FRONTEND_SYNC=1
