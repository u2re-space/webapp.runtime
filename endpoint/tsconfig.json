{
    "include": [
        "**/*.ts",
        "**/*.js"
    ],
    "exclude": [
        "./node_modules/**/*",
        "./dist/**/*",
        "./windows_use/**/*",
        "./portable/**/*",
        "./src/**/*.js",
        "./src/**/*.jsx"
    ],
    "baseUrl": "./",
    "compilerOptions": {
        "paths": {
            "@old/*": [
                "./server/*"
            ],
            "@old/airpad/*": [
                "./server/airpad/*"
            ],
            "@old/com/*": [
                "./server/com/*"
            ],
            "@old/lib/*": [
                "./server/lib/*"
            ],
            "@old/network/*": [
                "./server/network/*"
            ],
            "@old/routing/*": [
                "./server/routing/*"
            ],
            "@legacy/*": [
                "./server-v2/legacy/*"
            ],
            "@protocol/*": [
                "./server-v2/protocol/*"
            ],
            "@admin/*": [
                "./server-v2/admin/*"
            ],
            "@config/*": [
                "./server-v2/config/*"
            ],
            "@server-v2/*": [
                "./server-v2/"
            ],
            "@server/*": [
                "./server-v2/"
            ],
            "@inputs/*": [
                "./server-v2/inputs/*"
            ],
            "@utils/*": [
                "./server-v2/utils/*"
            ]
        },
        "outDir": "./dist/",
        "target": "ES2025",
        "module": "NodeNext",
        "moduleResolution": "NodeNext",
        "lib": [
            "ES2025",
            "DOM"
        ],
        "esModuleInterop": true,
        "allowImportingTsExtensions": true,
        "allowArbitraryExtensions": true,
        "allowSyntheticDefaultImports": true,
        "allowUmdGlobalAccess": true,
        "allowUnreachableCode": true,
        "allowUnusedLabels": true,
        "skipLibCheck": true,
        "strict": false,
        "noImplicitAny": false,
        "noImplicitThis": false,
        "forceConsistentCasingInFileNames": true,
        "allowJs": true,
        "declaration": false,
        "inlineSources": true,
        "inlineSourceMap": true,
        "sourceMap": false,
        "experimentalDecorators": true,
        "types": [
            "node"
        ],
        "noEmit": true,
        "noEmitOnError": true,
        "noEmitHelpers": true
    },
    "compileOnSave": false
}
